# Get these from your Supabase project dashboard:
# https://app.supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional: Vercel deploy hook URL (triggers a site rebuild when you publish a post)
# Create one at: Vercel Dashboard → Your Project → Settings → Git → Deploy Hooks
VITE_DEPLOY_HOOK_URL=

# Revalidation endpoint on your public site (triggers ISR cache refresh when you publish)
# For Next.js sites: https://yourdomain.com/admin/api/revalidate
VITE_REVALIDATE_URL=
