# ============================================================
# Knowledge Base Kit - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Your Identity (used in generated content) ---
YOUR_NAME="Your Name"
YOUR_BUSINESS="Your Business Name"
YOUR_WEBSITE="https://www.yourbusiness.com"
YOUR_YOUTUBE_HANDLE="@YourChannel"

# --- Anthropic (optional - for AI-enhanced content generation) ---
ANTHROPIC_API_KEY=""

# --- Python ---
# If your Python 3.10+ isn't the default, set the path:
# PYTHON_PATH="/usr/local/bin/python3"
